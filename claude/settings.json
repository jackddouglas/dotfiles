{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)",
      "Agent(*)",

      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(git revert *)",
      "Bash(git stash *)",
      "Bash(git branch *)",
      "Bash(git tag *)",
      "Bash(git switch *)",
      "Bash(git bisect *)",
      "Bash(git worktree *)",
      "Bash(git notes *)",
      "Bash(git mv *)",
      "Bash(git apply *)",
      "Bash(git am *)",

      "Bash(jj new *)",
      "Bash(jj commit *)",
      "Bash(jj describe *)",
      "Bash(jj edit *)",
      "Bash(jj squash *)",
      "Bash(jj rebase *)",
      "Bash(jj abandon *)",
      "Bash(jj restore *)",
      "Bash(jj split *)",
      "Bash(jj duplicate *)",
      "Bash(jj absorb *)",
      "Bash(jj bookmark *)",
      "Bash(jj log *)",
      "Bash(jj st *)",
      "Bash(jj status *)",
      "Bash(jj diff *)",
      "Bash(jj show *)",
      "Bash(jj undo)",
      "Bash(jj op log *)",
      "Bash(jj op undo *)",
      "Bash(jj op restore *)",
      "Bash(jj op show *)",
      "Bash(jj op diff *)",
      "Bash(jj git fetch *)",
      "Bash(jj next *)",
      "Bash(jj prev *)",
      "Bash(jj file *)",
      "Bash(jj parallelize *)",
      "Bash(jj resolve *)",
      "Bash(jj diffedit *)",
      "Bash(jj workspace add *)",
      "Bash(jj workspace list *)",
      "Bash(jj workspace root *)"
    ]
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "theme": "auto"
}
