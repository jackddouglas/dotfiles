{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @agent_alert '?' 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @agent_alert '✓' 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
