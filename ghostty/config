copy-on-select = true
mouse-hide-while-typing = true
macos-option-as-alt = true

# UI
macos-titlebar-style = hidden
theme = light:Flexoki Light,dark:Flexoki Dark

# Fonts
# font-family = Lilex
font-family = Berkeley Mono
font-style = Regular
font-style-bold = Bold
font-style-italic = Oblique
font-style-bold-italic = Bold Oblique
font-feature = +calt, +liga, +dlig
font-size = 12
adjust-cell-height = 10%

# Keybinds
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Cmd+N -> CSI-u Alt+N, consumed by tmux; ignored by other apps
keybind = cmd+digit_1=text:\x1b[49;3u
keybind = cmd+digit_2=text:\x1b[50;3u
keybind = cmd+digit_3=text:\x1b[51;3u
keybind = cmd+digit_4=text:\x1b[52;3u
keybind = cmd+digit_5=text:\x1b[53;3u
keybind = cmd+digit_6=text:\x1b[54;3u
keybind = cmd+digit_7=text:\x1b[55;3u
keybind = cmd+digit_8=text:\x1b[56;3u
keybind = cmd+digit_9=text:\x1b[57;3u

# Pane management
keybind = cmd+opt+backslash=new_split:right
keybind = cmd+opt+minus=new_split:down
keybind = cmd+opt+x=close_surface
keybind = cmd+opt+z=toggle_split_zoom

# Split navigation
keybind = cmd+opt+h=goto_split:left
keybind = cmd+opt+j=goto_split:down
keybind = cmd+opt+k=goto_split:up
keybind = cmd+opt+l=goto_split:right

# Split resizing
keybind = cmd+ctrl+h=resize_split:left,15
keybind = cmd+ctrl+j=resize_split:down,15
keybind = cmd+ctrl+k=resize_split:up,15
keybind = cmd+ctrl+l=resize_split:right,15
