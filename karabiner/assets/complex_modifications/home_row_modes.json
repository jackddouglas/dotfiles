          "to_if_alone": [{ "key_code": "k" }],
          "conditions": [
            { "type": "variable_unless", "name": "caps_layer", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "l", "modifiers": { "optional": ["any"] } },
