        {
          "type": "basic",
          "from": {
            "key_code": "semicolon",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "key_code": "right_shift", "lazy": true }],
          "to_if_alone": [{ "key_code": "semicolon" }],
          "conditions": [
            { "type": "variable_unless", "name": "caps_layer", "value": 1 }
          ]
        }
      ]
    }
  ]
