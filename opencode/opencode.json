{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "which *": "allow",
      "whereis *": "allow",
      "type *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "tree *": "allow",
      "pwd": "allow",
      "env": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "diff *": "allow",
      "jq *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git rev-parse *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git blame *": "allow",
      "git shortlog *": "allow",
      "git describe *": "allow",
      "git stash list": "allow",
      "git stash list *": "allow",
      "git config --get *": "allow",
      "git config --list": "allow",
      "git config --list *": "allow",
      "git branch": "allow",
      "git tag": "allow",
      "git remote": "allow"
    },
    "webfetch": "allow"
  }
}
